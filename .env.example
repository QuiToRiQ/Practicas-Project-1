# ---- Postgres ----
POSTGRES_DB=practicas
POSTGRES_USER=practicas
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=3001
NODE_ENV=development

# Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=replace-with-long-random-string-min-64-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-64-chars
JWT_ACCESS_TTL=900            # 15 minutes
JWT_REFRESH_TTL=1209600       # 14 days

# Storage backend: "local" | "azure" | "gcs"
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/data/uploads

# Cookies / CORS
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false           # set to true behind HTTPS

# Upload limits
MAX_UPLOAD_BYTES=52428800     # 50 MB
MAX_ROWS_PER_FILE=200000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ---- Frontend ----
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3001
